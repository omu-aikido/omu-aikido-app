{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:js-app"],
  "schedule": ["every 3 days"],
  "packageRules": [
    {
      "matchUpdateTypes": ["patch", "pin", "digest"],
      "minimumReleaseAge": "3 days",
      "automerge": true
    },
    {
      "matchDepTypes": ["devDependencies"],
      "minimumReleaseAge": "3 days",
      "automerge": true
    }
  ],
  "timezone": "Asia/Tokyo",
  "dashboard": false
}
